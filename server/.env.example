# ============================================
# サーバー .env
# ============================================
# コピーして使用: cp .env.example .env

# サーバーのリッスンポート
PORT=3001

# Google OAuth Client ID（Google Cloud Console で取得）
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com

# JWT 署名用シークレット（以下のコマンドで生成）
# openssl rand -base64 32
JWT_SECRET=your-random-secret-string

# 管理者の Google ユーザー ID（カンマ区切りで複数指定可）
ADMIN_USER_IDS=

# VAPID 鍵（プッシュ通知用、任意）
# npx web-push generate-vapid-keys で生成
# VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=
# VAPID_SUBJECT=mailto:your-email@example.com
