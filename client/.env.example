# ============================================
# クライアント .env
# ============================================
# コピーして使用: cp .env.example .env

# シグナリングサーバーの URL
VITE_SERVER_URL=http://localhost:3001

# Google OAuth Client ID（ルート .env の GOOGLE_CLIENT_ID と同じ値）
VITE_GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com

# VAPID 公開鍵（プッシュ通知用、任意）
# サーバー側の VAPID_PUBLIC_KEY と同じ値
# VITE_VAPID_PUBLIC_KEY=
