# ============================================
# ルート .env（docker-compose.yml が参照）
# ============================================
# コピーして使用: cp .env.example .env

# Google OAuth Client ID（Google Cloud Console で取得）
# https://console.cloud.google.com/ → APIとサービス → 認証情報
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com

# JWT 署名用シークレット（以下のコマンドで生成）
# openssl rand -base64 32
JWT_SECRET=your-random-secret-string

# 管理者の Google ユーザー ID（カンマ区切りで複数指定可）
# 初回ログイン後に server/data/users.json の sub フィールドで確認
ADMIN_USER_IDS=
